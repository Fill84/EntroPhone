# ========================================
# ClaudePhone2 - Natural SIP Voice Agent
# ========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to git!

# ========================================
# SIP Configuration (FreePBX)
# ========================================
SIP_SERVER=sip.example.com
SIP_USERNAME=1000
SIP_PASSWORD=your_sip_password
SIP_PROXY=
SIP_TRANSPORT=UDP
# Docker NAT: set your host's LAN IP
SIP_PUBLIC_IP=127.0.0.1
SIP_PUBLIC_PORT=5061
SIP_LOCAL_PORT=5061
SIP_RING_SECONDS=2
SIP_POST_ANSWER_DELAY=0.3
SIP_GREETING_DELAY=1.0
SIP_MAX_CALL_DURATION=1800
SIP_CALLBACK_NUMBER=9000
SIP_REGISTRATION_TIMEOUT=60

# ========================================
# Ollama AI Configuration
# ========================================
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=600
OLLAMA_TIMEOUT=30

# ========================================
# Speech-to-Text (faster-whisper)
# ========================================
STT_MODEL_SIZE=medium
STT_DEVICE=cuda
STT_COMPUTE_TYPE=auto
STT_LISTEN_MAX_DURATION=30

# ========================================
# Text-to-Speech (Piper)
# ========================================
TTS_VOICE_NL=mls
TTS_VOICE_EN=amy
TTS_QUALITY_NL=medium
TTS_QUALITY_EN=medium
TTS_VOLUME_GAIN_DB=1.5
TTS_LENGTH_SCALE=1.1

# ========================================
# Voice Activity Detection (Silero VAD)
# ========================================
VAD_THRESHOLD=0.4
VAD_MIN_SILENCE_MS=800
VAD_SPEECH_PAD_MS=300
VAD_MIN_SPEECH_MS=250

# ========================================
# Dashboard
# ========================================
DASHBOARD_PORT=8080
